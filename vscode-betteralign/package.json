{
  "name": "vscode-betteralign",
  "displayName": "Better Align for VS Code",
  "description": "VS Code extension for betteralign, a tool by dkorunic to optimize Go struct alignment",
  "version": "0.1.0",
  "publisher": "aceix",
  "repository": {
    "type": "git",
    "url": "https://github.com/dkorunic/betteralign.git",
    "directory": "vscode-betteralign"
  },
  "license": "BSD-3-Clause",
  "icon": "./logo.png",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "vscode:package": "vsce package",
    "openvsx:package": "ovsx package"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.116.0",
    "@vscode/vsce": "^3.9.1",
    "ovsx": "^0.10.11",
    "typescript": "^6.0.3"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./out/extension.js",
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "keywords": [
    "go",
    "golang",
    "alignment",
    "struct",
    "linter",
    "memory"
  ],
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onLanguage:go",
    "workspaceContains:**/*.go"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "In untrusted workspaces, workspace-scoped betteralign.extraArgs is ignored; only user- and machine-scoped settings apply."
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "betteralign.run",
        "title": "Betteralign: Run on current file",
        "enablement": "editorLangId == go"
      },
      {
        "command": "betteralign.apply",
        "title": "Betteralign: Apply fixes to current file",
        "enablement": "editorLangId == go"
      },
      {
        "command": "betteralign.installBinary",
        "title": "Betteralign: Install Binary"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "betteralign.run",
          "when": "editorLangId == go"
        },
        {
          "command": "betteralign.apply",
          "when": "editorLangId == go"
        }
      ]
    },
    "configuration": {
      "title": "betteralign",
      "properties": {
        "betteralign.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable betteralign extension"
        },
        "betteralign.runOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run betteralign on save"
        },
        "betteralign.applyPrompt": {
          "type": "string",
          "enum": [
            "onDiagnostics",
            "never"
          ],
          "default": "onDiagnostics",
          "description": "When to prompt to apply fixes after running betteralign"
        },
        "betteralign.severity": {
          "type": "string",
          "enum": [
            "information",
            "warning",
            "hint",
            "error"
          ],
          "default": "hint",
          "description": "Diagnostic severity for betteralign optimizations (color of squiggly line)"
        },
        "betteralign.debounceMs": {
          "type": "number",
          "default": 300,
          "minimum": 0,
          "maximum": 5000,
          "description": "Debounce delay (milliseconds) between a file save and the betteralign run. Rapid consecutive saves collapse into a single invocation."
        },
        "betteralign.binPath": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Custom path to betteralign binary. If empty, the extension will try to find it in PATH or GOPATH/bin. Machine-scoped: cannot be overridden from workspace settings for safety."
        },
        "betteralign.extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional CLI flags forwarded to betteralign. Only these are accepted: -test_files, -generated_files, -opt_in (boolean); -exclude_dirs=..., -exclude_files=... (use -flag=value form). Anything else is ignored."
        }
      }
    }
  }
}
